  <string name="bss_configure">Configura Opzioni</string>
  <string name="bss_opt_hotword">Disabilita rilevamento parola chiave</string>
  <string name="bss_opt_hotword_desc">Impedisce al microfono sempre attivo di ascoltare "Hey Google"</string>
  <string name="bss_opt_fullbackup">Posticipa backup completo</string>
  <string name="bss_opt_fullbackup_desc">Mette in pausa i backup completi del dispositivo quando il risparmio energetico è attivo. Riprende alla disattivazione.</string>
  <string name="bss_opt_keybackup">Posticipa backup chiave-valore</string>
  <string name="bss_opt_keybackup_desc">Mette in pausa la sincronizzazione delle impostazioni delle app e dei piccoli backup dei dati nel cloud.</string>
  <string name="bss_opt_force_standby">Forza standby delle app</string>
  <string name="bss_opt_force_standby_desc">Sposta tutte le app in background nel bucket di standby limitato, riducendo drasticamente i loro risvegli.</string>
  <string name="bss_opt_force_bg">Forza controllo in background</string>
  <string name="bss_opt_force_bg_desc">Applica un controllo più severo sui limiti di esecuzione in background per tutte le app.</string>
  <string name="bss_opt_sensors">Disabilita sensori opzionali</string>
  <string name="bss_opt_sensors_desc">Spegne i sensori non critici come barometro, contapassi e vettore di rotazione.</string>
  <string name="bss_opt_gps">Modalità di localizzazione</string>
  <string name="bss_apply">Applica & Chiudi</string>
  <string name="bss_gps_0">Nessuna restrizione</string>
  <string name="bss_gps_1">GPS disattivato (schermo spento)</string>
  <string name="bss_gps_2">Tutto disattivato (schermo spento)</string>
  <string name="bss_gps_3">Solo in primo piano</string>
  <string name="bss_gps_4">Limitazione (schermo spento)</string>
  <string name="bss_gps_hint_0">Il GPS e tutti i servizi di localizzazione funzionano normalmente in qualsiasi momento. Nessuna restrizione applicata.</string>
  <string name="bss_gps_hint_1">Il chip satellitare GPS si spegne quando lo schermo si spegne. La localizzazione Wi-Fi e cell-tower continuano a funzionare a precisione ridotta. Sicuro per la maggior parte della navigazione.</string>
  <string name="bss_gps_hint_2">Ogni provider di posizione - GPS, Wi-Fi e cella - si ferma quando lo schermo si spegne. I widget meteo, le mappe e i fitness tracker smettono di aggiornarsi in background.</string>
  <string name="bss_gps_hint_3">Solo l\'app sullo schermo può accedere alla posizione. A qualsiasi app in background viene negato l\'accesso, indipendentemente dai permessi concessi.</string>
  <string name="bss_gps_hint_4">Le app in background possono ancora ottenere la posizione, ma gli aggiornamenti sono limitati quando lo schermo è spento. Minor impatto sulla batteria con migliore compatibilità rispetto a una disattivazione completa.</string>
  <string name="bss_opt_datasaver">Abilita risparmio dati</string>
  <string name="bss_opt_datasaver_desc">Limita l\'uso dei dati in background per tutte le app mentre il risparmio energetico è attivo</string>
  <string name="tgl_soo">Ottimizzazione Schermo Spento</string>
  <string name="tgl_soo_desc">Disabilita le connessioni selezionate e termina le app in background dopo un ritardo allo spegnimento dello schermo. Ripristina allo sblocco.</string>
