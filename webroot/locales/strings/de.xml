  <string name="bss_opt_fullbackup">Vollständige Sicherung aufschieben</string>
  <string name="bss_opt_fullbackup_desc">Pausiert vollständige Gerätesicherungen, während der Energiesparmodus aktiv ist. Wird beim Deaktivieren fortgesetzt.</string>
  <string name="bss_opt_keybackup">Schlüssel-Wert-Sicherung aufschieben</string>
  <string name="bss_opt_keybackup_desc">Pausiert die Synchronisierung von App-Einstellungen und kleinen Datensicherungen in die Cloud.</string>
  <string name="bss_opt_force_standby">App-Standby erzwingen</string>
  <string name="bss_opt_force_standby_desc">Verschiebt alle Hintergrund-Apps in den eingeschränkten Standby-Bucket und begrenzt ihre Wakeups stark.</string>
  <string name="bss_opt_force_bg">Hintergrundprüfung erzwingen</string>
  <string name="bss_opt_force_bg_desc">Wendet strengere Durchsetzung von Hintergrundausführungslimits auf alle Apps an.</string>
  <string name="bss_opt_sensors">Optionale Sensoren deaktivieren</string>
  <string name="bss_opt_sensors_desc">Schaltet nicht-kritische Sensoren wie Barometer, Schrittzähler und Rotationsvektor ab.</string>
  <string name="bss_opt_gps">Standortmodus</string>
  <string name="bss_gps_0">Keine Einschränkung</string>
  <string name="bss_gps_1">GPS aus (Bildschirm aus)</string>
