  <string name="bss_opt_hotword">Désactiver la détection de mot-clé</string>
  <string name="bss_opt_hotword_desc">Empêche le micro permanent d'écouter « Hey Google »</string>
  <string name="bss_opt_fullbackup">Différer la sauvegarde complète</string>
  <string name="bss_opt_fullbackup_desc">Suspend les sauvegardes complètes de l'appareil lorsque l'économie de batterie est active. Reprise à la désactivation.</string>
  <string name="bss_opt_keybackup">Différer la sauvegarde clé-valeur</string>
  <string name="bss_opt_keybackup_desc">Suspend la synchronisation des paramètres d'application et des petites sauvegardes de données vers le cloud.</string>
  <string name="bss_opt_force_standby">Forcer la mise en veille des applications</string>
  <string name="bss_opt_force_standby_desc">Déplace toutes les applications en arrière-plan vers le bac de veille restreint, limitant fortement leurs réveils.</string>
  <string name="bss_opt_force_bg">Forcer la vérification en arrière-plan</string>
  <string name="bss_opt_force_bg_desc">Applique une application plus stricte des limites d'exécution en arrière-plan pour toutes les applications.</string>
  <string name="bss_opt_sensors">Désactiver les capteurs optionnels</string>
  <string name="bss_opt_sensors_desc">Désactive les capteurs non critiques comme le baromètre, le podomètre et le vecteur de rotation.</string>
  <string name="bss_opt_gps">Mode de localisation</string>
  <string name="bss_gps_0">Aucune restriction</string>
  <string name="bss_gps_1">GPS désactivé (écran éteint)</string>
  <string name="bss_gps_2">Tout désactivé (écran éteint)</string>
  <string name="bss_gps_3">Premier plan uniquement</string>
  <string name="bss_gps_4">Limité (écran éteint)</string>
  <string name="bss_gps_hint_0">Le GPS et tous les services de localisation fonctionnent normalement en permanence. Aucune restriction appliquée.</string>
  <string name="bss_gps_hint_1">La puce GPS satellite s'éteint lorsque l'écran s'éteint. La localisation Wi-Fi et cellulaire continue à précision réduite. Sûr pour la plupart des cas de navigation.</string>
  <string name="bss_gps_hint_2">Tous les fournisseurs de localisation – GPS, Wi-Fi et cellulaire – s'arrêtent lorsque l'écran s'éteint. Les widgets météo, cartes et traqueurs de fitness ne se mettent plus à jour en arrière-plan.</string>
  <string name="bss_gps_hint_3">Seule l'application au premier plan peut accéder à la localisation. Toute application en arrière-plan est entièrement bloquée, indépendamment des autorisations accordées.</string>
  <string name="bss_gps_hint_4">Les applications en arrière-plan peuvent toujours obtenir la localisation, mais les mises à jour sont limitées en débit lorsque l'écran est éteint. Moins d'impact sur la batterie avec une meilleure compatibilité qu'une désactivation complète.</string>
  <string name="bss_opt_datasaver">Activer l'économie de données</string>
  <string name="bss_opt_datasaver_desc">Restreint l'utilisation des données en arrière-plan pour toutes les applications lorsque l'économie de batterie est active</string>
