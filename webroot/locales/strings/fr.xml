  <string name="bss_configure">Configurer les options</string>
  <string name="bss_opt_hotword">Désactiver la détection de mot clé</string>
  <string name="bss_opt_hotword_desc">Empêche le microphone toujours actif d'écouter "Hey Google"</string>
  <string name="bss_opt_fullbackup">Différer la sauvegarde complète</string>
  <string name="bss_opt_fullbackup_desc">Met en pause les sauvegardes complètes de l'appareil lorsque l'économiseur est activé. Reprend une fois désactivé.</string>
  <string name="bss_opt_keybackup">Différer la sauvegarde clé-valeur</string>
  <string name="bss_opt_keybackup_desc">Met en pause la synchronisation des paramètres d'application et des petites sauvegardes de données dans le cloud.</string>
  <string name="bss_opt_force_standby">Forcer la mise en veille des apps</string>
  <string name="bss_opt_force_standby_desc">Déplace toutes les applications en arrière-plan vers un groupe de veille restreint, limitant fortement leurs réveils.</string>
  <string name="bss_opt_force_bg">Forcer la vérification en arrière-plan</string>
  <string name="bss_opt_force_bg_desc">Applique une application plus stricte des limites d'exécution en arrière-plan pour toutes les applications.</string>
  <string name="bss_opt_sensors">Désactiver les capteurs facultatifs</string>
  <string name="bss_opt_sensors_desc">Désactive les capteurs non critiques tels que le baromètre, le compteur de pas et le vecteur de rotation.</string>
  <string name="bss_opt_gps">Mode de localisation</string>
  <string name="bss_apply">Appliquer & Fermer</string>
  <string name="bss_gps_0">Aucune restriction</string>
  <string name="bss_gps_1">GPS désactivé (écran éteint)</string>
  <string name="bss_gps_2">Tout désactivé (écran éteint)</string>
  <string name="bss_gps_3">Premier plan uniquement</string>
  <string name="bss_gps_4">Limitation (écran éteint)</string>
  <string name="bss_gps_hint_0">Le GPS et tous les services de localisation fonctionnent normalement à tout moment. Aucune restriction appliquée.</string>
  <string name="bss_gps_hint_1">La puce satellite GPS s'éteint lorsque l'écran s'éteint. Le Wi-Fi et les antennes relais continuent de fonctionner avec une précision moindre. Sûr pour la plupart des usages de navigation.</string>
  <string name="bss_gps_hint_2">Tous les fournisseurs de localisation - GPS, Wi-Fi et antennes relais - s'arrêtent lorsque l'écran s'éteint. Les widgets météo, cartes et traqueurs d'activité cessent de se mettre à jour en arrière-plan.</string>
  <string name="bss_gps_hint_3">Seule l'application à l'écran peut accéder à la localisation. Toute application fonctionnant en arrière-plan est totalement bloquée, indépendamment des permissions accordées.</string>
  <string name="bss_gps_hint_4">Les applications en arrière-plan peuvent toujours obtenir la localisation, mais les mises à jour sont limitées en fréquence lorsque l'écran est éteint. Moins d'impact sur la batterie avec une meilleure compatibilité des applications qu'une désactivation totale.</string>
  <string name="bss_opt_datasaver">Activer l'économiseur de données</string>
  <string name="bss_opt_datasaver_desc">Restreint l'utilisation des données en arrière-plan pour toutes les applications lorsque l'économiseur de batterie est actif</string>
  <string name="tgl_soo">Optimisation Écran Éteint</string>
  <string name="tgl_soo_desc">Désactive les connexions sélectionnées et tue les applications en arrière-plan après un délai d'extinction de l'écran. Restaure au déverrouillage.</string>
