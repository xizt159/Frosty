  <string name="bss_opt_keybackup_desc">Pausa a sincronização de configurações de apps e backups de dados pequenos na nuvem.</string>
  <string name="bss_opt_force_standby">Forçar modo de espera dos apps</string>
  <string name="bss_opt_force_standby_desc">Move todos os apps em segundo plano para o bucket de espera restrito, limitando severamente suas ativações.</string>
  <string name="bss_opt_force_bg">Forçar verificação de segundo plano</string>
  <string name="bss_opt_force_bg_desc">Aplica uma fiscalização mais rígida dos limites de execução em segundo plano em todos os apps.</string>
  <string name="bss_opt_sensors">Desativar sensores opcionais</string>
  <string name="bss_opt_sensors_desc">Desliga sensores não críticos como barômetro, contador de passos e vetor de rotação.</string>
