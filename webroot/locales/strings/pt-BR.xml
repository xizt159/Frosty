  <string name="bss_configure">Configurar Opções</string>
  <string name="bss_opt_hotword">Desativar detecção de palavra-chave</string>
  <string name="bss_opt_hotword_desc">Impede que o microfone sempre ativo ouça "Ok Google"</string>
  <string name="bss_opt_fullbackup">Adiar backup completo</string>
  <string name="bss_opt_fullbackup_desc">Pausa os backups completos do dispositivo enquanto a economia de bateria está ativa. Retoma ao ser desligada.</string>
  <string name="bss_opt_keybackup">Adiar backup chave-valor</string>
  <string name="bss_opt_keybackup_desc">Pausa a sincronização das configurações do aplicativo e de pequenos backups de dados na nuvem.</string>
  <string name="bss_opt_force_standby">Forçar aplicativos em espera</string>
  <string name="bss_opt_force_standby_desc">Move todos os aplicativos em segundo plano para o grupo de espera restrito, limitando drasticamente seus despertares.</string>
  <string name="bss_opt_force_bg">Forçar verificação em segundo plano</string>
  <string name="bss_opt_force_bg_desc">Aplica uma fiscalização mais rigorosa dos limites de execução em segundo plano em todos os aplicativos.</string>
  <string name="bss_opt_sensors">Desativar sensores opcionais</string>
  <string name="bss_opt_sensors_desc">Desliga sensores não essenciais, como barômetro, contador de passos e vetor de rotação.</string>
  <string name="bss_opt_gps">Modo de localização</string>
  <string name="bss_apply">Aplicar e Fechar</string>
  <string name="bss_gps_0">Sem restrição</string>
  <string name="bss_gps_1">GPS desligado (tela desligada)</string>
  <string name="bss_gps_2">Tudo desligado (tela desligada)</string>
  <string name="bss_gps_3">Apenas primeiro plano</string>
  <string name="bss_gps_4">Limitação (tela desligada)</string>
  <string name="bss_gps_hint_0">O GPS e todos os serviços de localização funcionam normalmente em todos os momentos. Nenhuma restrição aplicada.</string>
  <string name="bss_gps_hint_1">O chip de satélite GPS desliga quando a tela apaga. A localização por Wi-Fi e torres de celular continua funcionando com menor precisão. Seguro para a maioria dos casos de navegação.</string>
  <string name="bss_gps_hint_2">Todos os provedores de localização (GPS, Wi-Fi e rede móvel) param quando a tela desliga. Widgets de clima, mapas e monitores de atividade física param de ser atualizados em segundo plano.</string>
  <string name="bss_gps_hint_3">Somente o aplicativo na tela pode acessar a localização. Qualquer aplicativo executado em segundo plano é totalmente negado, independentemente das permissões concedidas.</string>
  <string name="bss_gps_hint_4">Aplicativos em segundo plano ainda podem obter a localização, mas as atualizações têm limite de taxa quando a tela está desligada. Menor impacto na bateria com melhor compatibilidade de aplicativos do que a desativação total.</string>
  <string name="bss_opt_datasaver">Ativar economia de dados</string>
  <string name="bss_opt_datasaver_desc">Restringe o uso de dados em segundo plano para todos os aplicativos enquanto a economia de bateria está ativa</string>
  <string name="tgl_soo">Otimização de Tela Desligada</string>
  <string name="tgl_soo_desc">Desativa as conexões selecionadas e mata aplicativos em segundo plano após o atraso de tela desligada. Restaura ao desbloquear.</string>
