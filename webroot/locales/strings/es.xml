  <string name="bss_opt_hotword">Desactivar detección de palabra clave</string>
  <string name="bss_opt_hotword_desc">Detiene el micrófono siempre activo de escuchar "Ok Google"</string>
  <string name="bss_opt_fullbackup">Aplazar copia de seguridad completa</string>
  <string name="bss_opt_fullbackup_desc">Pausa las copias de seguridad completas del dispositivo mientras el ahorro de batería está activado. Se reanuda al desactivarse.</string>
  <string name="bss_opt_keybackup">Aplazar copia de seguridad clave-valor</string>
  <string name="bss_opt_keybackup_desc">Pausa la sincronización de ajustes de apps y copias de seguridad de datos pequeños en la nube.</string>
  <string name="bss_opt_force_standby">Forzar modo en espera de apps</string>
  <string name="bss_opt_force_standby_desc">Mueve todas las apps en segundo plano al bucket de espera restringido, limitando severamente sus activaciones.</string>
  <string name="bss_opt_force_bg">Forzar verificación de segundo plano</string>
  <string name="bss_opt_force_bg_desc">Aplica una aplicación más estricta de los límites de ejecución en segundo plano en todas las apps.</string>
  <string name="bss_opt_sensors">Desactivar sensores opcionales</string>
  <string name="bss_opt_sensors_desc">Apaga sensores no críticos como el barómetro, contador de pasos y vector de rotación.</string>
  <string name="bss_opt_gps">Modo de ubicación</string>
  <string name="bss_gps_0">Sin restricción</string>
  <string name="bss_gps_1">GPS apagado (pantalla apagada)</string>
  <string name="bss_gps_2">Todo apagado (pantalla apagada)</string>
  <string name="bss_gps_3">Solo primer plano</string>
  <string name="bss_gps_4">Limitar (pantalla apagada)</string>
  <string name="bss_gps_hint_0">GPS y todos los servicios de ubicación funcionan con normalidad en todo momento. Sin restricciones aplicadas.</string>
  <string name="bss_gps_hint_1">El chip de GPS satelital se apaga cuando la pantalla se apaga. La ubicación por Wi-Fi y torres de celular sigue funcionando con menor precisión. Seguro para la mayoría de los casos de navegación.</string>
  <string name="bss_gps_hint_2">Todos los proveedores de ubicación — GPS, Wi-Fi y torre de celular — se detienen cuando la pantalla se apaga. Widgets del clima, mapas y rastreadores de fitness dejan de actualizarse en segundo plano.</string>
  <string name="bss_gps_hint_3">Solo la app en pantalla puede acceder a la ubicación. Cualquier app en segundo plano es denegada completamente, independientemente de los permisos concedidos.</string>
  <string name="bss_gps_hint_4">Las apps en segundo plano aún pueden obtener la ubicación, pero las actualizaciones están limitadas por tasa cuando la pantalla está apagada. Menor impacto en la batería con mejor compatibilidad de apps que una desactivación completa.</string>
  <string name="bss_opt_datasaver">Activar ahorro de datos</string>
  <string name="bss_opt_datasaver_desc">Restringe el uso de datos en segundo plano para todas las apps mientras el ahorro de batería está activo</string>
