  <string name="bss_configure">Configurar Opciones</string>
  <string name="bss_opt_hotword">Deshabilitar detección de palabra clave</string>
  <string name="bss_opt_hotword_desc">Evita que el micrófono siempre activo escuche "Hey Google"</string>
  <string name="bss_opt_fullbackup">Aplazar copia de seguridad completa</string>
  <string name="bss_opt_fullbackup_desc">Pausa las copias de seguridad completas del dispositivo mientras el ahorro de batería está activo. Se reanuda cuando se desactiva.</string>
  <string name="bss_opt_keybackup">Aplazar copia de seguridad clave-valor</string>
  <string name="bss_opt_keybackup_desc">Pausa la sincronización de configuraciones de aplicaciones y pequeñas copias de seguridad de datos en la nube.</string>
  <string name="bss_opt_force_standby">Forzar aplicaciones en espera</string>
  <string name="bss_opt_force_standby_desc">Mueve todas las aplicaciones en segundo plano al grupo de espera restringido, limitando fuertemente sus despertares.</string>
  <string name="bss_opt_force_bg">Forzar verificación en segundo plano</string>
  <string name="bss_opt_force_bg_desc">Aplica un cumplimiento más estricto de los límites de ejecución en segundo plano para todas las aplicaciones.</string>
  <string name="bss_opt_sensors">Deshabilitar sensores opcionales</string>
  <string name="bss_opt_sensors_desc">Apaga sensores no críticos como el barómetro, el contador de pasos y el vector de rotación.</string>
  <string name="bss_opt_gps">Modo de ubicación</string>
  <string name="bss_apply">Aplicar y Cerrar</string>
  <string name="bss_gps_0">Sin restricción</string>
  <string name="bss_gps_1">GPS apagado (pantalla apagada)</string>
  <string name="bss_gps_2">Todo apagado (pantalla apagada)</string>
  <string name="bss_gps_3">Solo en primer plano</string>
  <string name="bss_gps_4">Limitación (pantalla apagada)</string>
  <string name="bss_gps_hint_0">El GPS y todos los servicios de ubicación funcionan normalmente en todo momento. No se aplican restricciones.</string>
  <string name="bss_gps_hint_1">El chip satelital del GPS se apaga cuando la pantalla se apaga. La ubicación por Wi-Fi y torres de telefonía sigue funcionando con menor precisión. Seguro para la mayoría de los casos de navegación.</string>
  <string name="bss_gps_hint_2">Todos los proveedores de ubicación (GPS, Wi-Fi y red móvil) se detienen cuando la pantalla se apaga. Los widgets meteorológicos, mapas y rastreadores de estado físico dejan de actualizarse en segundo plano.</string>
  <string name="bss_gps_hint_3">Solo la aplicación en pantalla puede acceder a la ubicación. A cualquier aplicación que se ejecute en segundo plano se le deniega por completo, independientemente de los permisos otorgados.</string>
  <string name="bss_gps_hint_4">Las aplicaciones en segundo plano aún pueden obtener la ubicación, pero las actualizaciones tienen un límite de frecuencia cuando la pantalla está apagada. Menor impacto en la batería con mejor compatibilidad de aplicaciones que una desactivación completa.</string>
  <string name="bss_opt_datasaver">Habilitar ahorro de datos</string>
  <string name="bss_opt_datasaver_desc">Restringe el uso de datos en segundo plano para todas las aplicaciones mientras el ahorro de batería está activo</string>
  <string name="tgl_soo">Optimización con Pantalla Apagada</string>
  <string name="tgl_soo_desc">Deshabilita las conexiones seleccionadas y mata las aplicaciones en segundo plano después de un retraso de pantalla apagada. Las restaura al desbloquear.</string>
