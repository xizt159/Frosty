  <string name="bss_opt_force_standby_desc">Memindahkan semua aplikasi latar belakang ke bucket siaga terbatas, sangat membatasi wakeups mereka.</string>
  <string name="bss_opt_force_bg">Paksa pemeriksaan latar belakang</string>
  <string name="bss_opt_force_bg_desc">Menerapkan penegakan batas eksekusi latar belakang yang lebih ketat di seluruh aplikasi.</string>
  <string name="bss_opt_sensors">Nonaktifkan sensor opsional</string>
  <string name="bss_opt_sensors_desc">Mematikan sensor non-kritis seperti barometer, penghitung langkah, dan vektor rotasi.</string>
  <string name="bss_opt_gps">Mode lokasi</string>
  <string name="bss_apply">Terapkan & Tutup</string>
  <string name="bss_gps_0">Tidak ada batasan</string>
  <string name="bss_gps_1">GPS mati (layar mati)</string>
  <string name="bss_gps_2">Semua mati (layar mati)</string>
  <string name="bss_gps_3">Hanya di latar depan</string>
  <string name="bss_gps_4">Batasi (layar mati)</string>
  <string name="bss_gps_hint_0">GPS dan semua layanan lokasi berfungsi normal setiap saat. Tidak ada batasan yang diterapkan.</string>
  <string name="bss_gps_hint_1">Chip satelit GPS mati saat layar mati. Lokasi Wi-Fi dan menara seluler tetap berfungsi pada akurasi yang lebih rendah. Aman untuk sebagian besar kasus penggunaan navigasi.</string>
  <string name="bss_gps_hint_2">Setiap penyedia lokasi - GPS, Wi-Fi, dan menara seluler - berhenti saat layar mati. Widget cuaca, peta, dan pelacak kebugaran berhenti memperbarui di latar belakang.</string>
  <string name="bss_gps_hint_3">Hanya aplikasi yang ada di layar yang dapat mengakses lokasi. Aplikasi apa pun yang berjalan di latar belakang sepenuhnya ditolak aksesnya, apa pun izin yang diberikan.</string>
  <string name="bss_gps_hint_4">Aplikasi latar belakang masih bisa mendapatkan lokasi, tetapi pembaruan dibatasi kecepatannya saat layar mati. Mengurangi dampak pada baterai dan memberikan kompatibilitas aplikasi yang lebih baik daripada penonaktifan penuh.</string>
