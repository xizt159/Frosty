  <string name="bss_opt_hotword">禁用唤醒词检测</string>
  <string name="bss_opt_hotword_desc">停止麦克风持续监听“Hey Google”</string>
  <string name="bss_opt_fullbackup">推迟完整备份</string>
  <string name="bss_opt_fullbackup_desc">开启省电模式时暂停设备完整备份，关闭后恢复。</string>
  <string name="bss_opt_keybackup">推迟键值备份</string>
  <string name="bss_opt_keybackup_desc">暂停应用设置和小型数据备份到云端的同步。</string>
  <string name="bss_opt_force_standby">强制应用待机</string>
  <string name="bss_opt_force_standby_desc">将所有后台应用移至受限的待机分组，严格限制其唤醒。</string>
  <string name="bss_opt_force_bg">强制后台检查</string>
  <string name="bss_opt_force_bg_desc">对所有应用实施更严格的后台执行限制。</string>
  <string name="bss_opt_sensors">禁用可选传感器</string>
  <string name="bss_opt_sensors_desc">关闭气压计、计步器和旋转矢量等非关键传感器。</string>
  <string name="bss_opt_gps">定位模式</string>
  <string name="bss_apply">应用并关闭</string>
  <string name="bss_gps_0">无限制</string>
  <string name="bss_gps_1">关闭 GPS (息屏)</string>
  <string name="bss_gps_2">全部关闭 (息屏)</string>
  <string name="bss_gps_3">仅前台</string>
  <string name="bss_gps_4">节流 (息屏)</string>
  <string name="bss_gps_hint_0">GPS 和所有定位服务始终正常工作。未应用任何限制。</string>
  <string name="bss_gps_hint_1">息屏时关闭 GPS 卫星芯片。Wi-Fi 和基站定位继续以较低精度工作。对于大多数导航用例来说是安全的。</string>
  <string name="bss_gps_hint_2">息屏时停止所有定位提供程序 (GPS、Wi-Fi 和基站)。天气小部件、地图和健身追踪器在后台停止更新。</string>
  <string name="bss_gps_hint_3">只有屏幕上的应用可以访问定位。完全拒绝任何在后台运行的应用的定位请求，无论其是否被授予权限。</string>
  <string name="bss_gps_hint_4">后台应用仍然可以获取定位，但息屏时更新频率受限。与完全禁用相比，对电池的影响更小，应用兼容性更好。</string>
  <string name="bss_opt_datasaver">启用流量节省程序</string>
  <string name="bss_opt_datasaver_desc">在省电模式处于活动状态时，限制所有应用的后台数据使用</string>
