  <string name="bss_opt_hotword">禁用语音唤醒</string>
  <string name="bss_opt_hotword_desc">停止麦克风常驻监听"Hey Google"</string>
  <string name="bss_opt_fullbackup">推迟完整备份</string>
  <string name="bss_opt_fullbackup_desc">在开启省电模式时暂停完整的设备备份。关闭省电模式时恢复。</string>
  <string name="bss_opt_keybackup">推迟键值备份</string>
  <string name="bss_opt_keybackup_desc">暂停应用设置和小型数据备份与云端的同步。</string>
  <string name="bss_opt_force_standby">强制应用待机</string>
  <string name="bss_opt_force_standby_desc">将所有后台应用移入受限待机组（standby bucket），大幅限制其唤醒。</string>
  <string name="bss_opt_force_bg">强制后台检查</string>
  <string name="bss_opt_force_bg_desc">对所有应用在后台的执行限制实施更严格的管控。</string>
  <string name="bss_opt_sensors">禁用可选传感器</string>
  <string name="bss_opt_sensors_desc">关闭非必要传感器，如气压计、计步器和旋转矢量传感器。</string>
  <string name="bss_opt_gps">定位模式</string>
  <string name="bss_gps_0">无限制</string>
  <string name="bss_gps_1">关闭 GPS（锁屏时）</string>
  <string name="bss_gps_2">关闭全部（锁屏时）</string>
  <string name="bss_gps_3">仅前台应用</string>
  <string name="bss_gps_4">限制频率（锁屏时）</string>
  <string name="bss_gps_hint_0">GPS 和所有定位服务在任何时候都正常工作，不受任何限制。</string>
  <string name="bss_gps_hint_1">屏幕关闭时，GPS 卫星芯片关闭。Wi-Fi 和基站定位继续以较低精度工作。对于大多数导航场景是安全的。</string>
  <string name="bss_gps_hint_2">屏幕关闭时，所有定位服务（GPS、Wi-Fi 和基站）都会停止。天气组件、地图和健身追踪应用将停止后台更新。</string>
  <string name="bss_gps_hint_3">只有处于前台屏幕上的应用才能访问定位。任何在后台运行的应用都会被完全拒绝访问，不论其被授予了何种权限。</string>
  <string name="bss_gps_hint_4">后台应用仍可获取位置，但在屏幕关闭时更新频率会受到限制。相比完全禁用，这种方式电量消耗更少，且应用兼容性更好。</string>
  <string name="bss_opt_datasaver">启用流量节省</string>
  <string name="bss_opt_datasaver_desc">在省电模式处于活跃状态时，限制所有后台应用的数据使用</string>
