  <string name="bss_opt_hotword_desc">Zatrzymuje zawsze włączony mikrofon przed nasłuchiwaniem „Hej Google"</string>
  <string name="bss_opt_fullbackup">Odrocz pełną kopię zapasową</string>
  <string name="bss_opt_fullbackup_desc">Wstrzymuje pełne kopie zapasowe urządzenia podczas włączonego oszczędzania baterii. Wznawia po wyłączeniu.</string>
  <string name="bss_opt_keybackup">Odrocz kopię zapasową klucz-wartość</string>
  <string name="bss_opt_keybackup_desc">Wstrzymuje synchronizację ustawień aplikacji i małych kopii zapasowych danych do chmury.</string>
  <string name="bss_opt_force_standby">Wymuś tryb czuwania aplikacji</string>
  <string name="bss_opt_force_standby_desc">Przenosi wszystkie aplikacje w tle do ograniczonego zasobnika czuwania, mocno ograniczając ich wybudzenia.</string>
  <string name="bss_opt_force_bg">Wymuś sprawdzanie tła</string>
  <string name="bss_opt_force_bg_desc">Stosuje bardziej rygorystyczne egzekwowanie limitów wykonywania w tle we wszystkich aplikacjach.</string>
  <string name="bss_opt_sensors">Wyłącz czujniki dodatkowe</string>
  <string name="bss_opt_sensors_desc">Wyłącza niekrytyczne czujniki, takie jak barometr, licznik kroków i wektor rotacji.</string>
  <string name="bss_opt_gps">Tryb lokalizacji</string>
  <string name="bss_gps_0">Bez ograniczeń</string>
  <string name="bss_gps_1">GPS wyłączony (ekran wyłączony)</string>
  <string name="bss_gps_2">Wszystko wyłączone (ekran wyłączony)</string>
  <string name="bss_gps_3">Tylko pierwszoplanowe</string>
  <string name="bss_gps_4">Ogranicz (ekran wyłączony)</string>
  <string name="bss_gps_hint_0">GPS i wszystkie usługi lokalizacji działają normalnie przez cały czas. Brak ograniczeń.</string>
  <string name="bss_gps_hint_1">Układ GPS wyłącza się po wygaszeniu ekranu. Lokalizacja Wi-Fi i stacji bazowych nadal działa z mniejszą dokładnością. Bezpieczne dla większości przypadków nawigacji.</string>
  <string name="bss_gps_hint_2">Każdy dostawca lokalizacji — GPS, Wi-Fi i stacje bazowe — zatrzymuje się po wygaszeniu ekranu. Widżety pogodowe, mapy i trackery fitness przestają się aktualizować w tle.</string>
  <string name="bss_gps_hint_3">Tylko aplikacja na ekranie ma dostęp do lokalizacji. Każda aplikacja działająca w tle jest całkowicie zablokowana, niezależnie od przyznanych uprawnień.</string>
  <string name="bss_gps_hint_4">Aplikacje w tle nadal mogą uzyskiwać lokalizację, ale aktualizacje są ograniczone częstotliwością po wygaszeniu ekranu. Mniejszy wpływ na baterię z lepszą kompatybilnością aplikacji niż pełne wyłączenie.</string>
  <string name="bss_opt_datasaver">Włącz oszczędzanie danych</string>
  <string name="bss_opt_datasaver_desc">Ogranicza użycie danych w tle dla wszystkich aplikacji podczas aktywnego oszczędzania baterii</string>
