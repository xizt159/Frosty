  <string name="bss_opt_keybackup_desc">Sospende la sincronizzazione delle impostazioni app e il backup di dati ridotti sul cloud.</string>
  <string name="bss_opt_force_standby">Forza standby app</string>
  <string name="bss_opt_force_standby_desc">Sposta tutte le app in background nel bucket standby con restrizioni, limitando fortemente i risvegli.</string>
  <string name="bss_opt_force_bg">Forza controllo background</string>
  <string name="bss_opt_force_bg_desc">Applica un'applicazione più rigorosa dei limiti di esecuzione in background a tutte le app.</string>
  <string name="bss_opt_sensors">Disabilita sensori opzionali</string>
  <string name="bss_opt_sensors_desc">Disattiva sensori non critici come barometro, contapassi e vettore di rotazione.</string>
  <string name="bss_opt_gps">Modalità posizione</string>
  <string name="bss_gps_0">Nessuna restrizione</string>
  <string name="bss_gps_1">GPS spento (schermo spento)</string>
  <string name="bss_gps_2">Tutto spento (schermo spento)</string>
  <string name="bss_gps_3">Solo in primo piano</string>
  <string name="bss_gps_4">Limitato (schermo spento)</string>
  <string name="bss_gps_hint_0">GPS e tutti i servizi di posizione funzionano normalmente sempre. Nessuna restrizione applicata.</string>
  <string name="bss_gps_hint_1">Il chip GPS satellite si spegne a schermo spento. La posizione Wi-Fi e cellulare continua con accuratezza inferiore. Sicuro per la maggior parte dei casi di navigazione.</string>
  <string name="bss_gps_hint_2">Ogni provider di posizione - GPS, Wi-Fi e cellulare - si ferma a schermo spento. Widget meteo, mappe e tracker fitness smettono di aggiornarsi in background.</string>
  <string name="bss_gps_hint_3">Solo l'app a schermo può accedere alla posizione. Qualsiasi app in background viene completamente negata, indipendentemente dai permessi concessi.</string>
  <string name="bss_gps_hint_4">Le app in background possono ancora ottenere la posizione, ma gli aggiornamenti sono limitati a schermo spento. Minor impatto sulla batteria con migliore compatibilità delle app rispetto alla disabilitazione completa.</string>
  <string name="bss_opt_datasaver">Attiva risparmio dati</string>
  <string name="bss_opt_datasaver_desc">Limita l'utilizzo di dati in background per tutte le app con il risparmio batteria attivo</string>
