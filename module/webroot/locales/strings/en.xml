  <string name="tgl_bss">Battery Saver Tuner</string>
  <string name="tgl_bss_desc">Tune Android's built-in battery saver behavior</string>
  <string name="bss_configure">Configure Options</string>
  <string name="bss_modal_title">Battery Saver Options</string>
  <string name="bss_opt_hotword">Disable hotword detection</string>
  <string name="bss_opt_hotword_desc">Stops the always-on microphone from listening for "Hey Google"</string>
  <string name="bss_opt_fullbackup">Defer full backup</string>
  <string name="bss_opt_fullbackup_desc">Pauses full device backups while battery saver is on. Resumes when turned off.</string>
  <string name="bss_opt_keybackup">Defer key-value backup</string>
  <string name="bss_opt_keybackup_desc">Pauses syncing of app settings and small data backups to the cloud.</string>
  <string name="bss_opt_force_standby">Force apps standby</string>
  <string name="bss_opt_force_standby_desc">Moves all background apps into the restricted standby bucket, heavily limiting their wakeups.</string>
  <string name="bss_opt_force_bg">Force background check</string>
  <string name="bss_opt_force_bg_desc">Applies stricter enforcement of background execution limits across all apps.</string>
  <string name="bss_opt_sensors">Disable optional sensors</string>
  <string name="bss_opt_sensors_desc">Turns off non-critical sensors like barometer, step counter, and rotation vector.</string>
  <string name="bss_opt_gps">Location mode</string>
  <string name="bss_gps_0">No restriction</string>
  <string name="bss_gps_1">GPS off (screen off)</string>
  <string name="bss_gps_2">All off (screen off)</string>
  <string name="bss_gps_3">Foreground only</string>
  <string name="bss_gps_4">Throttle (screen off)</string>
  <string name="bss_gps_hint_0">GPS and all location services work normally at all times. No restriction applied.</string>
  <string name="bss_gps_hint_1">GPS satellite chip shuts off when the screen goes off. Wi-Fi and cell-tower location keep working at lower accuracy. Safe for most navigation use cases.</string>
  <string name="bss_gps_hint_2">Every location provider - GPS, Wi-Fi, and cell tower - stops when the screen goes off. Weather widgets, maps, and fitness trackers stop updating in the background.</string>
  <string name="bss_gps_hint_3">Only the app on screen can access location. Any app running in the background is fully denied, regardless of permissions granted.</string>
  <string name="bss_gps_hint_4">Background apps can still get location, but updates are rate-limited when the screen is off. Less battery impact with better app compatibility than a full disable.</string>
  <string name="bss_opt_datasaver">Enable data saver</string>
  <string name="bss_opt_datasaver_desc">Restricts background data usage for all apps while battery saver is active</string>
